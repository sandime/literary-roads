rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Gazette: publicly readable, only Cloud Functions can write ────────────
    // newspaper.html reads gazette/currentIssue on every page load.
    // Writes happen only from the refreshGazette Cloud Function (admin SDK).
    match /gazette/{doc} {
      allow read: if true;
      allow write: if false; // admin SDK bypasses these rules
    }

    // ── Guestbook: public read, authenticated write ───────────────────────────
    // guestbooks/{locationId}/entries/{bookId}
    // addBookEntry uses setDoc; addRecommendationToEntry uses updateDoc (arrayUnion + increment)
    match /guestbooks/{locationId}/entries/{entryId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ── All other existing collections: auth required ─────────────────────────
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
