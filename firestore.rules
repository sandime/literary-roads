rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Admin helper ──────────────────────────────────────────────────────────
    function isAdmin() {
      return request.auth != null && request.auth.uid == 'LmsIBzI7KjMqERTsmXxjHULHJ3M2';
    }

    // ── Gazette metadata: publicly readable, admin-only write ─────────────────
    // gazette/currentIssue — read by newspaper renderer on every page load
    match /gazette/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Gazette archive: publicly readable, admin-only write ──────────────────
    // gazetteIssues/{slug} — read by /newspaper/archive and /newspaper/:slug
    match /gazetteIssues/{slug} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Gazette section collections: publicly readable, admin-only write ──────
    // Read by /newspaper/current, /newsletter, and archived issues.
    // Written only from AdminPanel.
    match /festivals/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /indiePicks/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /tripReports/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /bookTokPicks/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /literaryLandmarks/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /readingRoom/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /headlights/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /onTheRoad/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /waystation/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /bookstoreQA/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /theLongRoad/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /curatedRoutes/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── User data (private per user) ──────────────────────────────────────────
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      match /booksRead/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      match /savedRoutes/{routeId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      match /postcards/{postcardId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      match /libraryPostcards/{bookId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      match /libraryRecs/{recId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      match /libraryReadNext/{bookId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      match /savedStops/{stopId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      match /checkInHistory/{checkInId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      match /badges/{badgeId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      match /wantToRead/{bookId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      match /readingGoal/{doc} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      match /readingGoals/{doc} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      match /readingQuestHistory/{year} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      match /discoveredAuthors/{authorId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // ── Literary festival map data: public read, written only by Cloud Functions ─
    match /literaryFestivals/{doc} {
      allow read: if true;
      allow write: if false; // Cloud Functions use Admin SDK (bypasses rules)
    }

    // ── RSS feed configuration: admin-managed ────────────────────────────────
    match /rssFeeds/{doc} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // ── RSS drafts: admin inbox, written by Cloud Functions ──────────────────
    match /rssDrafts/{doc} {
      allow read: if isAdmin();
      allow write: if isAdmin(); // Cloud Functions (Admin SDK) bypass this
    }

    // ── Public read collections (map data) ────────────────────────────────────
    match /literary_landmarks/{landmark} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /literary_podcasts/{podcast} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /museums/{doc} {
      allow read: if true;
    }
    match /driveIns/{doc} {
      allow read: if true;
    }
    match /observatories/{doc} {
      allow read: if true;
    }
    match /parks/{doc} {
      allow read: if true;
    }
    match /artGalleries/{doc} {
      allow read: if true;
    }
    match /aquariums/{doc} {
      allow read: if true;
    }
    match /theaters/{doc} {
      allow read: if true;
    }

    // ── Location data: public read, auth required to write ───────────────────
    match /bookstores/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /coffeeShops/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /restaurants/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /historicSites/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /libraries/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ── Guestbook entries ─────────────────────────────────────────────────────
    match /guestbooks/{locationId}/entries/{entryId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ── Hitchhiker's Tale stories ─────────────────────────────────────────────
    match /hitchhikerStories/{storyId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null &&
                    request.resource.data.sentences.size() <= 100;
    }

    // ── Location ratings ──────────────────────────────────────────────────────
    match /locationRatings/{locationId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
    }

    // ── Active car check-ins ──────────────────────────────────────────────────
    match /activeCheckIns/{locationId}/cars/{checkInId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow delete: if request.auth != null &&
                    request.auth.uid == resource.data.userId;
    }

    // ── Honk notifications ────────────────────────────────────────────────────
    match /honkNotifications/{userId} {
      allow read, write: if request.auth != null;
    }

    // ── Shared routes ─────────────────────────────────────────────────────────
    match /sharedRoutes/{routeId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null &&
                    request.auth.uid == resource.data.createdBy.userId;
      allow delete: if request.auth != null &&
                    request.auth.uid == resource.data.createdBy.userId;
    }

    // ── App config flags: publicly readable, admin-only write ────────────────
    match /config/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Email / waitlist ──────────────────────────────────────────────────────
    match /emails/{email} {
      allow read: if false;
      allow write: if true;
    }
    match /internationalWaitlist/{emailId} {
      allow create: if true;
      allow read: if request.auth != null;
    }
  }
}
