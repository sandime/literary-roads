rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ── Journey poster images: public read, admin-only write ──────────────────
    match /journey-posters/{imageId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == 'LmsIBzI7KjMqERTsmXxjHULHJ3M2';
    }

    // ── Default: deny all ─────────────────────────────────────────────────────
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
