rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Public read for all files
    match /{allPaths=**} {
      allow read: if true;
    }

    // Journey poster images: admin-only write
    match /journey-posters/{imageId} {
      allow write: if request.auth != null && request.auth.uid == 'LmsIBzI7KjMqERTsmXxjHULHJ3M2';
    }

    // Guide cover images: authenticated write
    match /guideCovers/{guideId}/{fileName} {
      allow write: if request.auth != null;
    }

    // Store photos: authenticated write
    match /storePhotos/{storeId}/{fileName} {
      allow write: if request.auth != null;
    }
  }
}
